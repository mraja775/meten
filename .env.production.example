# Copy to .env.production.local on the deployment host and run chmod 600.
# Never commit the populated file.
POSTGRES_DB="meten"
POSTGRES_USER="meten"
POSTGRES_PASSWORD="generate-a-strong-database-password"
DATABASE_URL="postgresql://meten:URL_ENCODED_PASSWORD@postgres:5432/meten?schema=public"

BETTER_AUTH_SECRET="generate-at-least-32-random-characters"
BETTER_AUTH_URL="https://meten.example.com"
NEXT_PUBLIC_APP_URL="https://meten.example.com"

RESEND_API_KEY="re_replace_with_real_key"
RESEND_FROM_EMAIL="Meten <login@meten.example.com>"

S3_ENDPOINT="https://your-s3-compatible-endpoint"
S3_ACCESS_KEY_ID="replace-with-storage-access-key"
S3_SECRET_ACCESS_KEY="replace-with-storage-secret"
S3_BUCKET="meten-production"
S3_REGION="auto"
S3_PUBLIC_BASE_URL="https://assets.meten.example.com"
